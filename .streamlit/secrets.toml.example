# Streamlit Cloud Secrets 配置模板
# 部署到 Streamlit Cloud 时，在 App Settings → Secrets 中填入以下内容：
#
# SILICONFLOW_API_KEY = "你的API Key"
# SILICONFLOW_BASE_URL = "https://api.siliconflow.cn/v1"
# OCR_MODEL = "Qwen/Qwen3-VL-32B-Instruct"
# SOLVER_MODEL = "Qwen/Qwen2.5-32B-Instruct"
#
# 注意：这个文件只是一个参考模板，不要在这里填写真实的 Key！
# 真实的 Secrets 在 Streamlit Cloud 后台填写。
