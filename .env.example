# DeepPrep API 配置文件模板
# 复制此文件为 .env 并填入你的实际 API 密钥

# SiliconFlow API 密钥（从 https://siliconflow.cn 获取）
SILICONFLOW_API_KEY=your_api_key_here

# SiliconFlow API 地址
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# OCR 模型
OCR_MODEL=Qwen/Qwen3-VL-32B-Instruct

# 解题模型
SOLVER_MODEL=Qwen/Qwen2.5-32B-Instruct
